{
  "name": "@zhenglinxiong/aether-compiler",
  "version": "0.1.0",
  "description": "Aether compiler - Babel plugin for macro transformation",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "esbuild": "^0.27.4"
  },
  "peerDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-jsx": "^7.28.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@babel/core": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@types/node": "^22.0.0"
  }
}
